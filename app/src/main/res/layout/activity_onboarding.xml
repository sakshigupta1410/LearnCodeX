<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    android:padding="20dp">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <!-- Fixed height for quote TextView -->
            <TextView
                android:id="@+id/onboard_quote"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:gravity="center"
                android:layout_marginTop="30dp"
                android:fontFamily="@font/playfairdisplay_bold"
                android:text="Your coding journey\nstarts here..."
                android:textAlignment="center"
                android:textColor="#0D2844"
                android:textSize="12pt"
                android:textStyle="bold"
                android:maxLines="3"
                android:ellipsize="end" />


            <!-- Fixed image placement -->
            <ImageView
                android:id="@+id/logo"
                android:layout_width="280dp"
                android:layout_height="180dp"
                android:layout_marginTop="24dp"
                android:contentDescription="LearnCodeX Logo"
                android:scaleType="fitCenter"
                android:src="@drawable/learncodex_logo" />

            <!-- App Name -->
            <TextView
                android:id="@+id/app_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20pt"
                android:text="LearnCodeX"
                android:textColor="#0D2844"
                android:textSize="36sp"
                android:textStyle="bold"
                android:fontFamily="@font/orbitron_extrabold" />

            <!-- Sign up button -->
            <Button
                android:id="@+id/email_signup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="30pt"
                android:fontFamily="@font/gill_sans_nova_bold"
                android:text="Sign Up with Email"
                android:textColor="#FFFFFF"
                android:background="@drawable/rounded_button"
                android:textSize="18sp" />

            <!-- Spacer -->
            <View
                android:layout_width="match_parent"
                android:layout_height="30dp" />

            <!-- Login link -->
            <TextView
                android:id="@+id/tvLogin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#666666"
                android:textSize="16sp"
                android:text="Already have an account? Log In" />

            <!-- ProgressBar (initially hidden) -->

        </LinearLayout>
    </ScrollView>
</RelativeLayout>
